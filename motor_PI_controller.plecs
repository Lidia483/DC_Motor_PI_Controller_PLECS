            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#define Phase_A InputSignal(0,0)\n"
"#define Phase_B InputSignal(1,0)\n"
"#define speed_reference InputSignal(2,0)\n"
"\n"
"\n"
"#define Output_duty_cycle OutputSignal(0,0)\n"
"#define Output_speed_actual OutputSignal(1,0)\n"
"\n"
"\n"
"#include <stdio.h>\n"
"\n"
"\n"
"#define Ts 0.02F               // 20ms --> frequency = 50Hz\n"
"#define FT_k 95.37489F\n"
"#define FT_tau 0.071893F\n"
"\n"
"#define lambda 1.8F\n"
"#define kp ((FT_tau+(0.5F*Ts))/(FT_k*lambda))\n"
"#define Ti (FT_tau + (0.5F * Ts))\n"
"\n"
"int pulse_counter_reset_200 = 0.0F; \n"
"\n"
"float pulse_counter = 0.0F; \n"
"float speed_actual = 0.0F;\n"
"float number = 68.181818F; //convert to RPM 50Hz*60/44\n"
"\n"
"float speed_REF_rads = 0;\n"
"float actual_speed_rads = 0;\n"
"float duty_cycle1 = 0;\n"
"\n"
"float error = 0.0F;\n"
"float prev_error = 0.0F;\n"
"float pi_out = 0.0F;\n"
"float prev_pi_out = 0.0F;\n"
"float pi_out_sat = 0.0F;\n"
"float integral_error = 0.0F;\n"
"float detect_sat = 1.0F;"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "Output_duty_cycle = duty_cycle1;\n"
"Output_speed_actual = speed_actual;\n"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         "if (Phase_A == 1) {\n"
"     pulse_counter ++;  // Forward pulse detected  \n"
"}  \n"
"if (Phase_B == 1) {\n"
"     pulse_counter ++;  // Forward pulse detected  \n"
"}  \n"
"\n"
"pulse_counter_reset_200 ++;\n"
"\n"
"if (pulse_counter_reset_200 >= 200 ) {\n"
"\n"
"speed_actual =  pulse_counter*number; \n"
"\n"
"pulse_counter = 0;\n"
"pulse_counter_reset_200 = 0;\n"
"\n"
"\n"
"speed_REF_rads = (2*3.14/60)*speed_reference;\n"
"actual_speed_rads = (2*3.14/60)*speed_actual;\n"
"\n"
"error = speed_REF_rads - actual_speed_rads;\n"
"\n"
"// discrete time PI controller with Anti-windup\n"
"pi_out = prev_pi_out + kp * (error - prev_error) + (kp / Ti) * (Ts / 2) * (er"
"ror + prev_error);\n"
"\n"
"prev_error = error;  // save the actual error for the next iteration\n"
"\n"
"pi_out_sat = pi_out;\n"
"pi_out_sat = (pi_out_sat > 1.0F) ? 1.0F : pi_out_sat;\n"
"pi_out_sat = (pi_out_sat < 0.0F) ? 0.0F : pi_out_sat;\n"
"\n"
"prev_pi_out = pi_out_sat;  // save the actual pi_out for the next iteration\n"
"duty_cycle1 = pi_out_sat;   // The PI output is the duty-cycle\n"
"}\n"
"\n"
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
